{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",       "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus",    "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel",      "id": "stat",          "name": "Stat",                "version": "" },
    { "type": "panel",      "id": "timeseries",    "name": "Time series",         "version": "" },
    { "type": "panel",      "id": "table",         "name": "Table",               "version": "" },
    { "type": "panel",      "id": "bargauge",      "name": "Bar gauge",           "version": "" },
    { "type": "panel",      "id": "piechart",      "name": "Pie chart",           "version": "" },
    { "type": "panel",      "id": "statushistory", "name": "Status history",      "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Netdisco operational overview — inventory, polling health, job performance, SNMP failures",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Inventory",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short", "mappings": []
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Devices",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(netdisco_devices{tenant=~\"$tenant\"})", "legendFormat": "devices", "instant": true }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short", "mappings": []
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Device IPs",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(netdisco_device_ips{tenant=~\"$tenant\"})", "legendFormat": "ips", "instant": true }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short", "mappings": []
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "L2 Links",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(netdisco_device_links{tenant=~\"$tenant\"})", "legendFormat": "links", "instant": true }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short", "mappings": []
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "ARP Entries",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(netdisco_arp_entries{tenant=~\"$tenant\"})", "legendFormat": "arp", "instant": true }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short", "mappings": []
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "MAC Entries",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(netdisco_macs{tenant=~\"$tenant\"})", "legendFormat": "macs", "instant": true }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red",   "value": 1 }
          ]},
          "unit": "short", "mappings": []
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "SNMP Failures",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(netdisco_snmp_failures_devices{tenant=~\"$tenant\"})", "legendFormat": "failures", "instant": true }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Polling Health",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 43200 },
            { "color": "red",    "value": 90000 }
          ]},
          "unit": "s", "mappings": []
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 6 },
      "id": 7,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Stale Discover (> 25h)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "count(netdisco_device_discover_age_seconds{tenant=~\"$tenant\"} > 90000)", "legendFormat": "stale", "instant": true }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 43200 },
            { "color": "red",    "value": 90000 }
          ]},
          "unit": "s", "mappings": []
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 6 },
      "id": 8,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Stale Macsuck (> 25h)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "count(netdisco_device_macsuck_age_seconds{tenant=~\"$tenant\"} > 90000)", "legendFormat": "stale", "instant": true }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 43200 },
            { "color": "red",    "value": 90000 }
          ]},
          "unit": "s", "mappings": []
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 6 },
      "id": 9,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Stale Arpnip (> 25h)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "count(netdisco_device_arpnip_age_seconds{tenant=~\"$tenant\"} > 90000)", "legendFormat": "stale", "instant": true }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "lineWidth": 0, "fillOpacity": 80, "stacking": { "mode": "normal", "group": "A" } } },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 10 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Job Duration by Action (stacked, at completion time)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (action) (\n  netdisco_device_last_job_duration_seconds{tenant=~\"$tenant\", status=\"done\"}\n  and\n  changes(netdisco_device_last_job_timestamp_seconds{tenant=~\"$tenant\", status=\"done\"}[$__rate_interval]) > 0\n)",
          "legendFormat": "{{action}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (action) (\n  netdisco_device_last_job_duration_seconds{tenant=~\"$tenant\", status!=\"done\"}\n  and\n  changes(netdisco_device_last_job_timestamp_seconds{tenant=~\"$tenant\", status!=\"done\"}[$__rate_interval]) > 0\n)",
          "legendFormat": "{{action}} (failed)",
          "refId": "B"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 102,
      "title": "Job Performance",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Average Job Duration by Action",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "netdisco_job_duration_seconds{tenant=~\"$tenant\"}",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red",    "value": 300 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 12,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Duration (s)" }] },
      "title": "Slowest Devices (top 20)",
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "device": "Device", "action": "Action", "Value": "Duration (s)" } } }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(20, netdisco_slow_device_duration_seconds{tenant=~\"$tenant\"})",
          "legendFormat": "{{device}}",
          "instant": true,
          "refId": "A",
          "format": "table"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 103,
      "title": "SNMP Failures",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red",   "value": 1 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 29 },
      "id": 20,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Failures" }] },
      "title": "SNMP Failures by Device (top 50)",
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "device": "Device", "backend": "Backend", "Value": "Failures" } } }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(50, netdisco_snmp_failures_by_device{tenant=~\"$tenant\"})",
          "legendFormat": "{{device}}",
          "instant": true,
          "refId": "A",
          "format": "table"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 },
      "id": 104,
      "title": "Device Inventory",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 38 },
      "id": 30,
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "displayMode": "gradient", "valueMode": "color" },
      "title": "Devices by Vendor",
      "type": "bargauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sort_desc(topk(20, netdisco_devices_by_vendor{tenant=~\"$tenant\"}))",
          "legendFormat": "{{vendor}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "up" },         "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "down" },       "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "admin-down" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 38 },
      "id": 31,
      "options": { "pieType": "donut", "displayLabels": ["name", "percent"], "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Port State Breakdown",
      "type": "piechart",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(netdisco_device_ports_up{tenant=~\"$tenant\"})",         "legendFormat": "up",         "instant": true, "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(netdisco_device_ports_down{tenant=~\"$tenant\"})",       "legendFormat": "down",       "instant": true, "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(netdisco_device_ports_admin_down{tenant=~\"$tenant\"})", "legendFormat": "admin-down", "instant": true, "refId": "C" }
      ]
    }

  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["netdisco", "operations"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(netdisco_devices, tenant)",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "tenant",
        "options": [],
        "query": { "query": "label_values(netdisco_devices, tenant)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Tenant"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Netdisco - Operations",
  "uid": "netdisco-operations",
  "version": 1
}
